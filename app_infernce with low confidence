# ── Audio Loading ─────────────────────────────────────────────────────────────

def _load_audio(path: str) -> np.ndarray:
    ext = os.path.splitext(path)[1].lower()
    y   = None

    if ext in {".wav", ".flac", ".ogg"}:
        try:
            y, _ = librosa.load(path, sr=SAMPLE_RATE, mono=True)
        except Exception:
            pass

    if y is None:
        if not PYDUB_AVAILABLE:
            raise RuntimeError(
                f"Format '{ext}' requires pydub + ffmpeg.\n"
                "Install: pip install pydub  and add ffmpeg to PATH."
            )
        seg = AudioSegment.from_file(path)
        seg = seg.set_channels(1).set_frame_rate(SAMPLE_RATE)
        with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as tmp:
            tmp_path = tmp.name
        seg.export(tmp_path, format="wav")
        y, _ = librosa.load(tmp_path, sr=SAMPLE_RATE, mono=True)
        os.unlink(tmp_path)

    y_trim, _ = librosa.effects.trim(y, top_db=20)
    if len(y_trim) < 1600:
        y_trim = y

    rms = np.sqrt(np.mean(y_trim ** 2)) + 1e-9
    return (y_trim / rms * 0.1).astype(np.float32)


# ── Signal 1: MFCC Delta Variance ────────────────────────────────────────────
# EMPIRICALLY CALIBRATED from your debug data:
#   Real audio:  mfcc_var = 30–32  → fake_score ≈ 0.19–0.24
#   Fake audio:  mfcc_var = 51–61  → fake_score ≈ 0.84–0.96
#
# WHY HIGH VARIANCE = FAKE:
#   Modern TTS (ElevenLabs, OpenAI TTS) is over-expressive — it exaggerates
#   vocal dynamics. Real compressed phone audio (WhatsApp ogg, Gmail m4a)
#   is more dynamically flat due to codec normalisation.
#   Threshold set at 40.0 (midpoint of 32 and 51), slope=0.15.

def _score_mfcc_delta(y: np.ndarray) -> float:
    try:
        mfcc     = librosa.feature.mfcc(
                        y=y, sr=SAMPLE_RATE, n_mfcc=13,
                        n_fft=1024, hop_length=256)
        delta    = librosa.feature.delta(mfcc)
        mean_var = float(np.mean(np.var(delta, axis=1)))

        # HIGH variance = FAKE (over-expressive TTS)
        # Sigmoid centred at 40.0, calibrated from real observed values 30-32 vs 51-61
        fake_score = 1.0 / (1.0 + np.exp(-(mean_var - 40.0) * 0.15))
        print(f"  [DBG] mfcc_delta  mean_var={mean_var:.2f}  → fake={fake_score:.3f}")
        return float(np.clip(fake_score, 0.0, 1.0))
    except Exception as e:
        print(f"  [DBG] mfcc_delta error: {e}")
        return 0.45


# ── Signal 2: Pitch CV ────────────────────────────────────────────────────────
# EMPIRICALLY CALIBRATED:
#   Real audio:  pitch_cv = 0.11–0.19  → fake_score ≈ 0.06–0.22
#   Fake audio:  pitch_cv = 0.19–0.32  → fake_score ≈ 0.40–0.97
#
# WHY HIGH CV = FAKE:
#   Modern TTS over-performs naturalness by adding exaggerated pitch variety.
#   Real speech (especially compressed) has more constrained pitch range.
#   Threshold at 0.20, slope=30.

def _score_pitch_cv(y: np.ndarray) -> float:
    try:
        f0, voiced_flag, _ = librosa.pyin(
            y, fmin=60, fmax=400, sr=SAMPLE_RATE, frame_length=2048)

        if voiced_flag is None:
            voiced_f0 = f0[~np.isnan(f0)]
        else:
            voiced_f0 = f0[voiced_flag == 1]
        voiced_f0 = voiced_f0[~np.isnan(voiced_f0)]

        if len(voiced_f0) < 15:
            print(f"  [DBG] pitch  not enough voiced frames → 0.45")
            return 0.45

        cv         = float(np.std(voiced_f0) / (np.mean(voiced_f0) + 1e-9))
        # HIGH cv = FAKE (over-expressive pitch range)
        fake_score = 1.0 / (1.0 + np.exp(-(cv - 0.20) * 30))
        print(f"  [DBG] pitch_cv  cv={cv:.4f}  → fake={fake_score:.3f}")
        return float(np.clip(fake_score, 0.0, 1.0))
    except Exception as e:
        print(f"  [DBG] pitch error: {e}")
        return 0.45


# ── Signal 3: Spectral Centroid Variance ─────────────────────────────────────
# Spectral centroid = "brightness" of audio at each frame.
# TTS: centroid moves in a controlled, smooth arc.
# Real speech: centroid wanders unpredictably (room acoustics, breathing,
#              phone mic variation, codec noise).
#
# MEASURE: variance of frame-to-frame centroid CHANGE (delta centroid).
# Low delta-centroid variance = suspiciously smooth = more FAKE.
# High delta-centroid variance = natural wandering = more REAL.
#
# Threshold calibrated conservatively at 2000 Hz²  (tune if needed).

def _score_spectral_centroid(y: np.ndarray) -> float:
    try:
        centroid = librosa.feature.spectral_centroid(
                        y=y, sr=SAMPLE_RATE, n_fft=1024, hop_length=256)[0]
        delta_c  = np.diff(centroid)
        var_dc   = float(np.var(delta_c))

        # LOW variance = FAKE (smooth, controlled centroid)
        # sigmoid: low var -> high fake score
        fake_score = 1.0 / (1.0 + np.exp((var_dc - 20000.0) * 0.00015))
        print(f"  [DBG] centroid_delta_var={var_dc:.0f}  → fake={fake_score:.3f}")
        return float(np.clip(fake_score, 0.0, 1.0))
    except Exception as e:
        print(f"  [DBG] centroid error: {e}")
        return 0.45


# ── Signal 4: Energy Envelope Variance ───────────────────────────────────────
# RMS energy over time: how bursty is the loudness?
# Real speech: energy spikes sharply on consonants, drops in pauses.
# TTS: energy is more uniformly distributed — controlled and smooth.
#
# MEASURE: coefficient of variation of RMS energy frames.
# Low energy CV = unnaturally smooth = more FAKE.

def _score_energy_envelope(y: np.ndarray) -> float:
    try:
        rms    = librosa.feature.rms(y=y, frame_length=512, hop_length=256)[0]
        # Only voiced-ish frames (above 10th percentile)
        thresh = np.percentile(rms, 10)
        voiced = rms[rms > thresh]
        if len(voiced) < 10:
            return 0.45

        cv = float(np.std(voiced) / (np.mean(voiced) + 1e-9))
        # LOW cv = FAKE (unnaturally uniform energy)
        fake_score = 1.0 / (1.0 + np.exp((cv - 0.45) * 15))
        print(f"  [DBG] energy_cv={cv:.4f}  → fake={fake_score:.3f}")
        return float(np.clip(fake_score, 0.0, 1.0))
    except Exception as e:
        print(f"  [DBG] energy error: {e}")
        return 0.45


# ── LCNN debug only ───────────────────────────────────────────────────────────

def _lcnn_debug(y: np.ndarray):
    """Runs LCNN and prints debug. NOT used in verdict — kept for monitoring."""
    try:
        S   = librosa.feature.melspectrogram(
                y=y, sr=SAMPLE_RATE, n_mels=IMG_SIZE, n_fft=1024, hop_length=512)
        mel = librosa.power_to_db(S, ref=np.max)
        mel = (mel - mel.mean()) / (mel.std() + 1e-8)
        t   = torch.tensor(mel, dtype=torch.float32).unsqueeze(0).unsqueeze(0)
        t   = F.interpolate(t, size=(IMG_SIZE, IMG_SIZE),
                            mode="bilinear", align_corners=False).to(device)
        with torch.no_grad():
            logits = _get_model()(t)
            raw    = logits.cpu().numpy()[0]
            prob   = float(torch.softmax(logits / TEMPERATURE, dim=1
                                         ).cpu().numpy()[0][1])
        print(f"  [DBG] lcnn  logits=({raw[0]:.1f},{raw[1]:.1f})  "
              f"fake_prob(T={TEMPERATURE})={prob:.3f}  [NOT used in verdict]")
    except Exception:
        pass


# ── Ensemble ──────────────────────────────────────────────────────────────────

def _combine(scores: dict) -> float:
    return sum(WEIGHTS[k] * scores[k] for k in WEIGHTS)


