        print(f"  BATCH SUMMARY  ({n} files)   "
              f"REAL: {real_count}   FAKE: {fake_count}   ERRORS: {err_count}")
        print(f"  {'─'*64}")
        for r in results:
            if r["error"]:
                print(f"  ✗  {r['file']:<36}  ERROR: {r['error']}")
                continue
            v   = r["verdict"]
            col = fake_col if v == "FAKE" else real_col
            low = f"  {mid_col}⚠ low{reset}" if r["low_confidence"] else ""
            print(f"  {col}{v:<4}{reset}  {r['file']:<36}  "
                  f"Real {r['real_pct']:5.1f}%  Fake {r['fake_pct']:5.1f}%  "
                  f"Conf {r['confidence']:5.1f}%{low}")
        print(f"{'='*68}\n")
