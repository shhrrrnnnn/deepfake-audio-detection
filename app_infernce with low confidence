    n        = len(paths)
    results  = []
    fake_col = "\033[91m"
    real_col = "\033[92m"
    mid_col  = "\033[93m"
    reset    = "\033[0m"

    print(f"\n{'='*58}")
    print(f"  BATCH MODE — {n} file(s) selected")
    print(f"{'='*58}")

    for i, path in enumerate(paths, 1):
        print(f"\n[{i}/{n}] Analysing: {os.path.basename(path)} ...")
        result = analyse(path)
